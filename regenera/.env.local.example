# ─── SUPABASE ────────────────────────────────────────────────
# Obtener desde: supabase.com → tu proyecto → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Solo para operaciones admin (nunca exponer al cliente)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── OPENAI ──────────────────────────────────────────────────
# Obtener desde: platform.openai.com → API Keys
OPENAI_API_KEY=sk-proj-...

# ─── WOMPI (pagos Colombia) ──────────────────────────────────
# Obtener desde: comercios.wompi.co → Developers
WOMPI_PUBLIC_KEY=pub_test_...
WOMPI_PRIVATE_KEY=prv_test_...
WOMPI_EVENTS_SECRET=...    # Para validar webhooks

# ─── APP ─────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Regenera

# Email del equipo Regenera (recibe escalaciones)
REGENERA_SUPPORT_EMAIL=soporte@regenera.com.co

# ─── EMAIL (Resend) ──────────────────────────────────────────
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=noreply@regenera.com.co
